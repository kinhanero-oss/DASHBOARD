    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FOCO NA FARDA - PMBA</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .topic-checked {
            opacity: 0.5;
            text-decoration: line-through;
        }
    </style>
</head>
<body class="p-4 pb-20 max-w-md mx-auto bg-slate-50 min-h-screen">
    <header class="mb-8 mt-4">
        <h1 class="text-3xl font-black text-slate-900 tracking-tight">FOCO NA FARDA PMBA</h1>
        <p class="text-sm font-bold text-slate-500 uppercase tracking-widest">Edital Completo e Detalhado</p>
        
        <div class="mt-6 bg-blue-600 rounded-3xl p-6 text-white shadow-xl shadow-blue-200">
            <div class="flex justify-between items-end">
                <div>
                    <p class="text-xs font-bold opacity-80 uppercase">Progresso Geral</p>
                    <h2 id="total-percent" class="text-4xl font-black">0%</h2>
                </div>
                <div class="text-right">
                    <p id="total-count" class="text-[10px] font-bold opacity-80 uppercase">0 de 0 Tópicos</p>
                </div>
            </div>
            <div class="mt-4 h-2 w-full bg-blue-400/30 rounded-full overflow-hidden">
                <div id="total-bar" class="h-full bg-white rounded-full transition-all duration-500" style="width: 0%"></div>
            </div>
        </div>
    </header>

    <div id="edital-container" class="space-y-6">
        <!-- Conteúdo gerado via JS -->
    </div>

