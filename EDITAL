                ]
            },
            {
                materia: "Atualidades",
                topicos: [
                    "1. Globalização: conceitos e efeitos",
                    "1.1. Implicações sociais, econômicas, políticas e culturais da globalização",
                    "2. Multiculturalidade, Pluralidade e Diversidade Cultural",
                    "3. Tecnologias de Informação e Comunicação: conceitos e efeitos",
                    "3.1. Implicações sociais, econômicas, políticas e culturais das TICs"
                ]
            },
            {
                materia: "Informática",
                topicos: [
                    "1. Edição de textos (Word, Writer)",
