            {
                materia: "Igualdade Racial e de Gênero",
                topicos: [
                    "1. CF/88 (art. 1°, 3°, 4° e 5°)",
                    "2. Constituição do Estado da Bahia (Cap. XXIII 'Do Negro')",
                    "3. Lei n° 12.288/2010 (Estatuto da Igualdade Racial)",
                    "4. Lei nº 7.716/1989 (Crimes de preconceito de raça ou cor)",
                    "4.1. Lei n° 9.459/1997 (Tipificação de crimes de preconceito)",
                    "5. Decreto n° 65.810/1969 (Eliminação da discriminação racial)",
                    "6. Decreto n° 4.377/2002 (Eliminação da discriminação contra a mulher)",
                    "7. Lei nº 11.340/2006 (Lei Maria da Penha)",
                    "8. Código Penal Brasileiro (art. 140)",
                    "9. Lei n° 9.455/1997 (Crime de Tortura)",
                    "11. Lei nº 7.437/1985 (Lei Caó)",
                    "12. Lei Estadual n° 10.549/2006 (Secretaria de Promoção da Igualdade Racial)",
                    "13. Lei nº 10.678/2003 (Secretaria de Políticas de Promoção da Igualdade Racial)"
                ]
            },
            {
                materia: "Direito Penal Militar",
                topicos: [
                    "1. Crimes contra a autoridade: motim, revolta, conspiração",
                    "1.1. Aliciação para motim ou revolta",
                    "2. Da violência contra superior ou militar de serviço",
                    "3. Desrespeito a superior",
                    "4. Recusa de obediência",
                    "5. Reunião ilícita",
                    "6. Publicação ou crítica indevida",
                    "7. Resistência mediante ameaça ou violência",
                    "8. Crimes contra o dever militar: deserção e abandono de posto",
                    "8.1. Descumprimento de missão, embriaguez e dormir em serviço",
                    "9. Crimes contra a Administração Militar: desacato a superior e a militar",
                    "9.1. Desobediência, peculato, peculato-furto e concussão",
                    "10. Dos crimes contra o dever funcional: prevaricação"
                ]
            }
        ];

        const container = document.getElementById('edital-container');
        let totalItems = 0;
        let completedItems = 0;

        function renderEdital() {
            container.innerHTML = '';
            totalItems = 0;
            completedItems = 0;

            editalData.forEach((item, materiaIdx) => {
                const materiaCompleted = item.topicos.filter((_, tIdx) => 
                    localStorage.getItem(`foco-pmba-${materiaIdx}-${tIdx}`) === 'true'
                ).length;
                
                const percent = Math.round((materiaCompleted / item.topicos.length) * 100);
                totalItems += item.topicos.length;
                completedItems += materiaCompleted;

                const card = document.createElement('div');
                card.className = "bg-white rounded-[2.5rem] border border-slate-100 overflow-hidden shadow-sm";
                
                card.innerHTML = `
                    <div class="p-6 flex justify-between items-center bg-slate-50/80">
                        <div class="max-w-[70%]">
                            <h3 class="text-sm font-black text-slate-800 leading-tight">${item.materia}</h3>
                            <p class="text-[10px] font-bold text-blue-600 uppercase mt-1">${materiaCompleted} de ${item.topicos.length} TÓPICOS</p>
                        </div>
                        <div class="w-12 h-12 rounded-full border-4 border-slate-200 relative flex items-center justify-center">
                            <svg class="absolute inset-0 w-full h-full -rotate-90">
                                <circle cx="24" cy="24" r="20" stroke="currentColor" stroke-width="4" fill="transparent" 
                                    class="text-blue-600 transition-all duration-700" style="stroke-dasharray: 126; stroke-dashoffset: ${126 - (126 * percent / 100)}"/>
                            </svg>
                            <span class="text-[10px] font-black">${percent}%</span>
                        </div>
                    </div>
                    <div class="p-4 space-y-2">
                        ${item.topicos.map((topico, topicoIdx) => {
                            const isDone = localStorage.getItem(`foco-pmba-${materiaIdx}-${topicoIdx}`) === 'true';
                            return `
                                <div onclick="toggleTopic(${materiaIdx}, ${topicoIdx})" 
                                     class="flex items-center gap-3 p-4 bg-white rounded-2xl border border-slate-100 cursor-pointer transition-all hover:bg-slate-50 ${isDone ? 'topic-checked' : ''}">
                                    <div class="w-5 h-5 rounded-lg border-2 flex-shrink-0 flex items-center justify-center transition-all ${isDone ? 'bg-blue-600 border-blue-600 shadow-lg shadow-blue-100' : 'border-slate-200'}">
                                        ${isDone ? '<svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/></svg>' : ''}
                                    </div>
                                    <span class="text-[11px] font-bold text-slate-700 leading-snug">${topico}</span>
                                </div>
                            `;
                        }).join('')}
                    </div>
                `;
                container.appendChild(card);
            });

            updateHeader();
        }

        function toggleTopic(mIdx, tIdx) {
            const key = `foco-pmba-${mIdx}-${tIdx}`;
            const current = localStorage.getItem(key) === 'true';
            localStorage.setItem(key, !current);
            renderEdital();
        }

        function updateHeader() {
            const totalPercent = Math.round((completedItems / totalItems) * 100) || 0;
            document.getElementById('total-percent').innerText = `${totalPercent}%`;
            document.getElementById('total-count').innerText = `${completedItems} DE ${totalItems} TÓPICOS`;
            document.getElementById('total-bar').style.width = `${totalPercent}%`;
        }

        window.onload = renderEdital;
    </script>
</body>
</html>
